                    }
                    @* @if (User.IsInRole("GERENCIA") || User.IsInRole("ADMINISTRADOR"))
                    {
                        <li>
                            <a asp-controller="Orden" asp-action="Gerencia" class="flex items-center p-2 rounded-lg text-white hover:bg-gray-700 group">
                                <svg class="shrink-0 w-5 h-5 transition duration-75 text-gray-400 group-hover:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M11.644 1.59a.75.75 0 0 1 .712 0l9.75 5.25a.75.75 0 0 1 0 1.32l-9.75 5.25a.75.75 0 0 1-.712 0l-9.75-5.25a.75.75 0 0 1 0-1.32l9.75-5.25Z" />
                                    <path d="m3.265 10.602 7.668 4.129a2.25 2.25 0 0 0 2.134 0l7.668-4.13 1.37.739a.75.75 0 0 1 0 1.32l-9.75 5.25a.75.75 0 0 1-.712 0l-9.75-5.25a.75.75 0 0 1 0-1.32l1.372-.738Z" />
                                    <path d="m10.933 19.231-7.668-4.13-1.37.739a.75.75 0 0 0 0 1.32l9.75 5.25c.221.12.491.12.712 0l9.75-5.25a.75.75 0 0 0 0-1.32l-1.37-.738-7.668 4.13a2.25 2.25 0 0 1-2.136-.001Z" />
                                </svg>
                                <span class="flex-1 ms-3 leading-tight">ORDEN DE COMPRAS (PRE AUTORIZADOS)</span>
                            </a>
                        </li>
                    } *@
                    

                    <li>
                        <span class="nav-text text-muted small text-white">
                            Rol: @(User.IsInRole("ADMINISTRADOR") ? "ADMINISTRADOR" : "USUARIO GENERAL")
                        </span>
                    </li>
                </ul>
            </div>
        </aside>

        <div id="main-content" class="main-content p-4 sm:ml-64 pt-[5rem]">
            @RenderBody()
        </div>
    </div>

    <!-- Scripts necesarios -->
    <script>
        // Función para toggle del sidebar en desktop
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('toggle-sidebar-desktop');
            const sidebar = document.getElementById('separator-sidebar');
            const mainContent = document.getElementById('main-content');

            if (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('sidebar-collapsed');
                });
            }

            // Función para toggle del submenu
            const currentPath = window.location.pathname.toLowerCase();
            console.log('Current path:', currentPath);

            // Marcar item activo
            document.querySelectorAll('aside a').forEach(link => {
                const href = link.getAttribute('href');

                if (href && href !== '#') {
                    const linkPath = href.toLowerCase();

                    if (currentPath === linkPath || (linkPath.length > 1 && currentPath.startsWith(linkPath))) {
                        link.classList.add('menu-item-active');
                        console.log('Match found:', href);

                        const parentSubmenu = link.closest('.submenu');
                        if (parentSubmenu) {
                            parentSubmenu.classList.add('open');
                            const arrow = document.getElementById('arrow-reportes');
                            if (arrow) arrow.style.transform = 'rotate(180deg)';
                        }
                    }
                }
            });
        });

        function toggleSubmenu(event) {
            event.preventDefault();
            const submenu = document.getElementById('submenu-reportes');
            const arrow = document.getElementById('arrow-reportes');

            if (submenu && arrow) {
                submenu.classList.toggle('open');
                arrow.style.transform = submenu.classList.contains('open') ? 'rotate(180deg)' : 'rotate(0deg)';
            }
        }
    </script>

    <script src="/lib/jquey_3.6.4.js"></script>
    <script src="/lib/jszip.min.js"></script>
    <script src="/lib/pdfmake.min.js"></script>
    <script src="/lib/vfs_fonts.js"></script>
    <script src="/lib/sweetalert2011.js"></script>
    <script src="/lib/select2.min.js"></script>
    <script src="/lib/flowbite.min.js"></script>
    <script src="/lib/print.min.js"></script>
    <script src="/lib/selectize.min.js"></script>
</body>
</html>