@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="keywords" content="">
    <meta name="author" content="">
    <meta name="robots" content="">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Fillow : Fillow Saas Admin  Bootstrap 5 Template">
    <meta property="og:title" content="Fillow : Fillow Saas Admin  Bootstrap 5 Template">
    <meta property="og:description" content="Fillow : Fillow Saas Admin  Bootstrap 5 Template">
    <meta property="og:image" content="https:/fillow.dexignlab.com/xhtml/social-image.png">
    <meta name="format-detection" content="telephone=no">

    <!-- PAGE TITLE HERE -->
    <title>Orion</title>

    <link rel="shortcut icon" type="image/x-icon" href="~/images/FAVICON.png">
    <!-- FAVICONS ICON -->
    <script src="/lib/tailwindcss.js"></script>

    <link href="/lib/flowbite.min.css" rel="stylesheet" />
    <!-- CDN Links para DataTables y dependencias -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="/lib/fontawesome.min.css" rel="stylesheet" />
    <link href="/lib/select2.min.css" rel="stylesheet" />
    <link href="/lib/selectize.default.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/datatablesmy.css" />
    <link rel="stylesheet" href="~/css/subMenu.css" />

    <style>
        /* Estilos para el sidebar colapsado */
        #separator-sidebar {
            transition: width 0.3s ease;
        }

            #separator-sidebar.collapsed {
                width: 4rem !important;
            }

                #separator-sidebar.collapsed .nav-text,
                #separator-sidebar.collapsed .flex-1 {
                    display: none;
                }

                #separator-sidebar.collapsed .submenu {
                    display: none !important;
                }

        .main-content {
            transition: margin-left 0.3s ease;
        }

            .main-content.sidebar-collapsed {
                margin-left: 4rem !important;
            }

        /* Tooltip para iconos cuando está colapsado */
        .sidebar-tooltip {
            position: relative;
        }

            .sidebar-tooltip:hover::after {
                content: attr(data-tooltip);
                position: absolute;
                left: 100%;
                top: 50%;
                transform: translateY(-50%);
                margin-left: 0.5rem;
                padding: 0.5rem 0.75rem;
                background-color: #1f2937;
                color: white;
                border-radius: 0.375rem;
                white-space: nowrap;
                z-index: 50;
                font-size: 0.875rem;
            }

        #separator-sidebar.collapsed .sidebar-tooltip:hover::after {
            display: block;
        }

        #separator-sidebar:not(.collapsed) .sidebar-tooltip:hover::after {
            display: none;
        }
    </style>
</head>
<body class="bg-gray-700" translate="no">
    <div id="">

        <nav class="border-gray-200 bg-gray-900 fixed w-full z-30">
            <div class="max-w-screen-xl flex flex-wrap items-center justify-between w-full p-0 min-w-full">

                <!-- Logo y Botón Hamburguesa -->
                <div class="flex items-center space-x-3 ml-2.5">
                    <!-- Botón Hamburguesa para Desktop -->
                    <button id="toggle-sidebar-desktop" type="button"
                            class="hidden sm:inline-flex items-center p-2 text-gray-400 rounded-lg hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-600">
                        <span class="sr-only">Toggle sidebar</span>
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
                        </svg>
                    </button>

                    <a asp-controller="Home" asp-action="Index" class="flex items-center space-x-3">
                        <img src="~/images/FAVICON.png" class="h-16" alt="Logo" />
                        <span class="text-2xl font-semibold text-white">Orion</span>
                    </a>
                </div>

                <!-- User/Admin Menu -->
                <div class="hidden md:flex items-center space-x-4 relative">
                    <div class="relative">
                        <button type="button" id="user-menu-button" data-dropdown-toggle="user-dropdown"
                                class="flex items-center p-2 rounded-full bg-gray-800 focus:ring-2 focus:ring-gray-600">
                            <span class="sr-only">Open user menu</span>
                            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                                <path fill-rule="evenodd"
                                      d="M12 20a7.966 7.966 0 0 1-5.002-1.756v-.683c0-1.794 1.492-3.25 3.333-3.25h3.334c1.84 0 3.333 1.456 3.333 3.25v.683A7.966 7.966 0 0 1 12 20ZM2 12C2 6.477 6.477 2 12 2s10 4.477 10 10c0 5.5-4.44 9.963-9.932 10h-.138C6.438 21.962 2 17.5 2 12Zm10-5c-1.84 0-3.333 1.455-3.333 3.25S10.159 13.5 12 13.5c1.84 0 3.333-1.455 3.333-3.25S13.841 7 12 7Z"
                                      clip-rule="evenodd" />
                            </svg>
                        </button>

                        <!-- Dropdown menú alineado a la derecha con margen  -->
                        <div id="user-dropdown"
                             class="hidden absolute right-[20px] mt-2 w-48 bg-white rounded-md shadow-lg py-2 z-50">
                            <div class="px-4 py-3">
                                <span class="block text-gray-900">@User.Identity.Name</span>
                            </div>
                            <ul class="py-2">
                                <li>
                                    <a asp-controller="Home" asp-action="CerrarSesion"
                                       class="block px-4 py-2 text-gray-700 hover:bg-gray-100">Cerrar Sesión</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Mobile menu button -->
                <div class="md:hidden flex items-center">
                    <button data-drawer-toggle="separator-sidebar" type="button"
                            class="p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-600">
                        <span class="sr-only">Open sidebar</span>
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
