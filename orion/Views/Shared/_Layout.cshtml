                    }

                    @if (User.IsInRole("COMPRAS") || User.IsInRole("ADMINISTRADOR") || User.IsInRole("PLANTA") || User.IsInRole("ALMACEN") || User.IsInRole("GERENCIA"))
                    {


                        
