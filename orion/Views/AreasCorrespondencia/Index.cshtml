<div class="space-y-6">
    <div class="bg-gray-800 rounded-xl p-6 shadow-2xl border border-gray-700">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="p-3 bg-indigo-600 rounded-lg">
                    <i class="fas fa-sitemap text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">Áreas CORRESPONDE A.S.C.</h1>
                    <p class="text-gray-400 text-sm">Administración de áreas para orden de compra</p>
                </div>
            </div>

            <button id="btnNuevaArea" type="button"
                    class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg hover:bg-indigo-700">
                <i class="fas fa-plus mr-2"></i>
                Nueva Área
            </button>
        </div>
    </div>

    <div class="container-fluid mt-5" style="padding-top:0">
        <div id="myGridAreas" class="ag-theme-quartz-dark" style="height:65vh"></div>
    </div>
</div>

<div id="modalArea" tabindex="-1" aria-hidden="true"
     class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-2xl max-h-full">
        <div class="relative bg-gray-800 rounded-lg shadow-2xl border border-gray-700">
            <div class="flex items-center justify-between p-4 border-b border-gray-600">
                <h3 id="titleModalArea" class="text-lg font-semibold text-white">NUEVA ÁREA</h3>
                <button type="button" onclick="cerrarModalArea()" class="text-gray-400 hover:text-white">✕</button>
            </div>

            <form id="formularioArea" class="p-4 space-y-4">
                <input type="hidden" name="Id" value="0" />

                <div>
                    <label class="block mb-2 text-sm font-medium text-white">Nombre</label>
                    <input type="text" name="Nombre" required
                           class="uppercase bg-gray-700 border border-gray-600 text-white text-sm rounded-lg block w-full p-2.5"
                           placeholder="Ej. SISTEMAS">
                </div>

                <div>
                    <label class="block mb-2 text-sm font-medium text-white">Estado</label>
                    <select name="Estado" class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg block w-full p-2.5">
                        <option value="A">ACTIVO</option>
                        <option value="I">INACTIVO</option>
                    </select>
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-gray-600">
                    <button type="button" onclick="cerrarModalArea()" class="py-2.5 px-5 text-sm font-medium text-gray-300 bg-gray-700 rounded-lg">Cancelar</button>
                    <button type="submit" class="py-2.5 px-5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.noStyle.js"></script>
<script src="~/lib/ag_grid/ag-grid.min.js"></script>
<script src="~/js/pages/areasCorrespondencia.js"></script>
