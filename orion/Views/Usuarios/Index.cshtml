﻿
<div class="space-y-6">
    <!-- Header con título -->
    <div class="bg-gray-800 rounded-xl p-6 shadow-2xl border border-gray-700">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="p-3 bg-blue-600 rounded-lg">
                    <i class="fas fa-users text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">Gestión de Usuarios</h1>
                    <p class="text-gray-400 text-sm">Administra los usuarios del sistema</p>
                </div>
            </div>

            <!-- Botón Agregar Usuario -->
            <button id="btnNuevoUsuario"
                    type="button"
                    class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:z-10 focus:ring-4 focus:ring-blue-300 transition-all duration-200 hover:scale-105 hover:shadow-lg">
                <i class="fas fa-plus mr-2"></i>
                Nuevo Usuario
            </button>

        </div>
    </div>

    <div class="container-fluid mt-5" style="padding-top:0">
        <div id="myGridUsuarios" class="ag-theme-quartz-dark" style="height:65vh"></div>
    </div>



</div>

<!-- Modal Agregar/Editar Usuario -->
<div id="modalRegistroUsuario" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-gray-800 rounded-lg shadow-2xl border border-gray-700">
            <!-- Modal header -->
            <div class="flex items-center justify-between p-4 md:p-5 border-b border-gray-600 rounded-t">
                <h3 id="titleModalUsuario" class="text-lg font-semibold text-white">
                    Nuevo Usuario
                </h3>
                <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-600 hover:text-white rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center transition-colors" onclick="cerrarModal()">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                    </svg>
                    <span class="sr-only">Cerrar modal</span>
                </button>
            </div>

            <!-- Modal body -->
            <form id="formularioUsuario" class="p-4 md:p-5">
                <input type="hidden" id="id" name="id">

                <div class="grid gap-4 mb-4 grid-cols-1">
                    <!-- Nombre -->
                    <div>
                        <label for="Nombre" class="block mb-2 text-sm font-medium text-white">
                            <i class="fas fa-user mr-2 text-blue-400"></i>Nombre *
                        </label>
                        <input type="text" name="Nombre" id="Nombre" class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors" placeholder="Ingrese el nombre" required="">
                    </div>

                    <!-- Contraseña -->
                    <div class="relative">
                        <label for="contraseña" class="block mb-2 text-sm font-medium text-white">
                            <i class="fas fa-lock mr-2 text-blue-400"></i>Contraseña *
                        </label>

                        <input type="password" name="contraseña" id="contraseña"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg
               focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5
               placeholder-gray-400 transition-colors pr-10"
                               placeholder="••••••••">
                        <button type="button" id="togglePassword"
                                class="absolute toast-top-center right-3 -translate-y-4 text-gray-400 hover:text-white">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <!-- Nombre Completo -->
                    <div>
                        <label for="NomCompleto" class="block mb-2 text-sm font-medium text-white">
                            <i class="fas fa-id-card mr-2 text-blue-400"></i>Nombre Completo *
                        </label>
                        <input type="text" name="NomCompleto" id="NomCompleto"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="Ingrese el nombre completo" required>
                    </div>

                    <!-- Tipo y Estado en una fila -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="idTipo" class="block mb-2 text-sm font-medium text-white">
                                <i class="fas fa-user-tag mr-2 text-blue-400"></i>Tipo *
                            </label>
                            <select id="idTipo" name="idTipo" class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 transition-colors" required>
                                <option value="ADMINISTRADOR">ADMINISTRADOR</option>
                                <option value="GERENCIA">GERENCIA</option>
                                <option value="COMPRAS">COMPRAS</option>
                                <option value="ALMACEN">ALMACEN</option>
                            </select>
                        </div>

                        <div>
                            <label for="estado" class="block mb-2 text-sm font-medium text-white">
                                <i class="fas fa-toggle-on mr-2 text-blue-400"></i>Estado *
                            </label>
                            <select id="estado" name="estado" class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 transition-colors" required>
                                <option value="1">ACTIVO</option>
                                <option value="2">INACTIVO</option>
                            </select>
                        </div>
                    </div>

                    <!-- ID Usuario -->
                    <div>
                        <label for="idUsuario" class="block mb-2 text-sm font-medium text-white">
                            <i class="fas fa-id-badge mr-2 text-blue-400"></i>ID Usuario *
                        </label>
                        <input type="text" name="idUsuario" id="idUsuario" class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors" placeholder="Ingrese ID de usuario">
                    </div>
                </div>

                <!-- Botones del modal -->
                <div class="flex justify-end gap-3">
                    <button type="button" onclick="cerrarModal()" class="py-2.5 px-5 text-sm font-medium text-gray-300 focus:outline-none bg-gray-700 rounded-lg border border-gray-600 hover:bg-gray-600 hover:text-white focus:z-10 focus:ring-4 focus:ring-gray-700 transition-colors">
                        <i class="fas fa-times mr-2"></i>Cancelar
                    </button>
                    <button type="submit" class="text-white inline-flex items-center bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition-colors">
                        <i class="fas fa-save mr-2"></i>Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/ag_grid/ag-grid.min.js"></script>
<script src="~/js/pages/usuarios.js"></script>


