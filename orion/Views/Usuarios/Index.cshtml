﻿
<div class="space-y-6">
    <!-- Header con título -->
    <div class="bg-gray-800 rounded-xl p-6 shadow-2xl border border-gray-700">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <div class="p-3 bg-blue-600 rounded-lg">
                    <i class="fas fa-users text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-white">Gestión de Usuarios</h1>
                    <p class="text-gray-400 text-sm">Administra los usuarios del sistema</p>
                </div>
            </div>

            <!-- Botón Agregar Usuario -->
            <button id="btnNuevoUsuario"
                    type="button"
                    class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-lg hover:bg-blue-700 focus:z-10 focus:ring-4 focus:ring-blue-300 transition-all duration-200 hover:scale-105 hover:shadow-lg">
                <i class="fas fa-plus mr-2"></i>
                Nuevo Usuario
            </button>

        </div>
    </div>

    <div class="container-fluid mt-5" style="padding-top:0">
        <div id="myGridUsuarios" class="ag-theme-quartz-dark" style="height:65vh; font-size: 12px;"></div>
    </div>



</div>
<!-- Modal Agregar/Editar Usuario -->
<div id="modalRegistroUsuario" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-lg max-h-full">
        <div class="relative bg-gray-800 rounded-lg shadow-2xl border border-gray-700">

            <!-- Modal header -->
            <div class="flex items-center justify-between p-4 md:p-5 border-b border-gray-600 rounded-t">
                <h3 id="titleModalUsuario" class="text-lg font-semibold text-white">Nuevo Usuario</h3>
                <button type="button" onclick="cerrarModal()" class="text-gray-400 bg-transparent hover:bg-gray-600 hover:text-white rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center transition-colors">
                    <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6" />
                    </svg>
                </button>
            </div>

            <!-- Modal body -->
            <form id="formularioUsuario" class="p-4 md:p-5">
                <input type="hidden" id="id" name="id">

                <div class="grid gap-4 mb-4 grid-cols-1 md:grid-cols-2">

                    <!-- Nombre de usuario -->
                    <div>
                        <label for="Nombre" class="block mb-2 text-sm font-medium text-white">Nombre *</label>
                        <input type="text" name="Nombre" id="Nombre"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="usuario123" required>
                    </div>

                    <!-- Contraseña -->
                    <div>
                        <label for="contraseña" class="block mb-2 text-sm font-medium text-white">Contraseña *</label>
                        <div class="relative">
                            <input type="password" name="contraseña" id="contraseña"
                                   class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 pr-10 placeholder-gray-400 transition-colors"
                                   placeholder="••••••••">
                            <button type="button" id="togglePassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white transition-colors">
                                <i class="fas fa-eye text-sm"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Nombre Completo (ancho completo) -->
                    <div class="md:col-span-2">
                        <label for="NomCompleto" class="block mb-2 text-sm font-medium text-white">Nombre Completo *</label>
                        <input type="text" name="NomCompleto" id="NomCompleto"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="Nombre y apellidos" required>
                    </div>

                    <!-- ID Usuario -->
                    <div>
                        <label for="idUsuario" class="block mb-2 text-sm font-medium text-white">ID Usuario *</label>
                        <input type="text" name="idUsuario" id="idUsuario"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="ID-001">
                    </div>

                    <!-- Área -->
                    <div>
                        <label for="area" class="block mb-2 text-sm font-medium text-white">Área</label>
                        <select id="area" name="Area"
                                class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 transition-colors">
                            <option value="">Sin área</option>
                            <option value="LACTEOS">LACTEOS</option>
                            <option value="GALLETERIA">GALLETERIA</option>
                            <option value="PANADERIA">PANADERIA</option>
                            <option value="SOYA">SOYA</option>
                            <option value="ALAMO">ALAMO</option>
                            <option value="CARSA">CARSA</option>
                            <option value="TECALIM">TECALIM</option>
                        </select>
                    </div>

                    <!-- Tipo -->
                    <div>
                        <label for="idTipo" class="block mb-2 text-sm font-medium text-white">Tipo *</label>
                        <select id="idTipo" name="idTipo"
                                class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 transition-colors" required>
                            <option value="ADMINISTRADOR">ADMINISTRADOR</option>
                            <option value="GERENCIA">GERENCIA</option>
                            <option value="COMPRAS">COMPRAS</option>
                            <option value="ALMACEN">ALMACEN</option>
                            <option value="PLANTA">PLANTA</option>
                            <option value="CONTABILIDAD">CONTABILIDAD</option>
                        </select>
                    </div>

                    <!-- Estado -->
                    <div>
                        <label for="estado" class="block mb-2 text-sm font-medium text-white">Estado *</label>
                        <select id="estado" name="estado"
                                class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 transition-colors" required>
                            <option value="1">ACTIVO</option>
                            <option value="2">INACTIVO</option>
                        </select>
                    </div>

                    <!-- Email (ancho completo) -->
                    <div class="md:col-span-2">
                        <label for="Email" class="block mb-2 text-sm font-medium text-white">Correo Electrónico</label>
                        <input type="email" name="Email" id="Email"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="correo@ejemplo.com">
                    </div>

                    <!-- Email Responsable (ancho completo) -->
                    <div class="md:col-span-2">
                        <label for="EmailResponsable" class="block mb-2 text-sm font-medium text-white">Correo Responsable</label>
                        <input type="email" name="EmailResponsable" id="EmailResponsable"
                               class="bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5 placeholder-gray-400 transition-colors"
                               placeholder="responsable@ejemplo.com">
                        <p class="mt-1 text-xs text-gray-400">Recibirá notificaciones de las solicitudes del usuario</p>
                    </div>

                </div>

                <!-- Botones -->
                <div class="flex justify-end gap-3 pt-4 border-t border-gray-600">
                    <button type="button" onclick="cerrarModal()"
                            class="py-2.5 px-5 text-sm font-medium text-gray-300 focus:outline-none bg-gray-700 rounded-lg border border-gray-600 hover:bg-gray-600 hover:text-white focus:z-10 focus:ring-4 focus:ring-gray-700 transition-colors">
                        <i class="fas fa-times mr-2"></i>Cancelar
                    </button>
                    <button type="submit"
                            class="text-white inline-flex items-center bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center transition-colors">
                        <i class="fas fa-save mr-2"></i>Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="~/lib/ag_grid/ag-grid.min.js"></script>
<script src="~/js/pages/usuarios.js"></script>


